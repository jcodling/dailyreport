# Claude Code CLI is used for AI curation — no API key needed here.

# ── FTP (optional) ────────────────────────────────────────────────
# Fill these in to enable automatic upload/download with IONOS.
# Leave blank to run locally without FTP sync.

FTP_HOST=ftp.yourdomain.com
FTP_USER=your-ftp-username
FTP_PASS=your-ftp-password

# Absolute path on FTP server to the reports directory inside public/.
# Connect via FTP and run `pwd` to find your root, then append the path.
# Example: /dailyreport/public/reports
FTP_REMOTE_REPORTS_DIR=/path/to/public/reports
