API_KEY=your-secret-api-key-here

# Optional: for scripts/cron-trigger.ts when testing locally
# SERVER_URL=http://localhost:3001

# FTP credentials for SFTP sync (IONOS)
# FTP_HOST=your-ftp-host
# FTP_USER=your-ftp-user
# FTP_PASS=your-ftp-password
# FTP_REMOTE_REPORTS_DIR=/path/to/reports/on/server

# Google OAuth for web UI (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_EMAIL=

# Target directory for web deployment
# TARGET_DIR=/path/on/server
